<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fjalla+One&family=Lato:wght@400;700;900&family=Special+Elite&display=swap" rel="stylesheet">

{{ 'gothrider-design-system.css' | asset_url | stylesheet_tag }}
{{ 'gothrider-header.css' | asset_url | stylesheet_tag }}
{{ 'gothrider-product.css' | asset_url | stylesheet_tag }}
{{ 'gothrider-collection.css' | asset_url | stylesheet_tag }}
{{ 'gothrider-cart.css' | asset_url | stylesheet_tag }}

<script
  src="{{ 'gothrider-cart.js' | asset_url }}"
  defer
  data-threshold="{{ settings.gr_free_shipping_threshold | default: 7500 }}"
  data-currency="{{ cart.currency.symbol | default: '$' }}"
  data-upsell-collection="{{ settings.gr_cart_upsell_collection | default: '' }}"
  data-upsell-limit="6"
  data-qualified-text="{{ 'general.cart.free_shipping_qualified' | t | default: 'You qualify for free shipping!' }}"
  data-remaining-text="{{ 'general.cart.free_shipping_remaining' | t | default: 'away from free shipping' }}"
  data-upsell-title="{{ 'general.cart.upsell_title' | t | default: 'You might also like' }}"
></script>

{% if settings.gr_enable_scroll_reveal %}
  <script src="{{ 'gothrider-scroll-reveal.js' | asset_url }}" defer></script>
{% endif %}

<style>
  :root {
    --gr-blood-red: {{ settings.gr_color_primary }};
    --gr-black: {{ settings.gr_color_background }};
    --gr-surface: {{ settings.gr_color_surface }};
    --gr-bone-white: {{ settings.gr_color_accent }};
    --gr-text-primary: {{ settings.gr_color_text }};
  }
</style>
