{%- assign blog = blogs[section.settings.blog] -%}

<div class="gr-section gr-reveal" {{ section.shopify_attributes }}>
  <div class="gr-container">
    {% if section.settings.heading != blank %}
      <div class="gr-blog-grid__header">
        <h2 class="gr-heading gr-heading-xl">{{ section.settings.heading }}</h2>
        {% if blog and section.settings.view_all_label != blank %}
          <a href="{{ blog.url }}" class="gr-btn gr-btn--ghost">{{ section.settings.view_all_label }}</a>
        {% endif %}
      </div>
    {% endif %}

    <div class="gr-blog-grid gr-blog-grid--{{ section.settings.columns }}">
      {% if blog %}
        {% for article in blog.articles limit: section.settings.posts_to_show %}
          <article class="gr-blog-card gr-card">
            {% if article.image %}
              <a href="{{ article.url }}" class="gr-blog-card__media">
                {{ article.image | image_url: width: 600 | image_tag:
                  loading: 'lazy',
                  sizes: '(min-width: 1024px) 33vw, 100vw',
                  widths: '300, 400, 600',
                  class: 'gr-blog-card__img'
                }}
              </a>
            {% endif %}
            <div class="gr-blog-card__content">
              <div class="gr-blog-card__meta">
                {% if article.tags.size > 0 %}
                  <span class="gr-blog-card__tag">{{ article.tags.first }}</span>
                {% endif %}
                <time class="gr-blog-card__date" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                  {{ article.published_at | date: '%B %d, %Y' }}
                </time>
              </div>
              <h3 class="gr-blog-card__title">
                <a href="{{ article.url }}">{{ article.title }}</a>
              </h3>
              {% if section.settings.show_excerpt and article.excerpt != blank %}
                <p class="gr-blog-card__excerpt">{{ article.excerpt | strip_html | truncatewords: 20 }}</p>
              {% endif %}
            </div>
          </article>
        {% endfor %}
      {% else %}
        {% for i in (1..3) %}
          <article class="gr-blog-card gr-card">
            <div class="gr-blog-card__media gr-bg-surface" style="aspect-ratio: 16/9; display: flex; align-items: center; justify-content: center;">
              {{ 'blog-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
            <div class="gr-blog-card__content">
              <div class="gr-blog-card__meta">
                <span class="gr-blog-card__tag">Coffee</span>
                <time class="gr-blog-card__date">February 22, 2026</time>
              </div>
              <h3 class="gr-blog-card__title"><a href="#">Sample Blog Post {{ forloop.index }}</a></h3>
            </div>
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</div>

<style>
  .gr-blog-grid__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--gr-space-2xl);
    gap: var(--gr-space-md);
  }

  .gr-blog-grid {
    display: grid;
    gap: var(--gr-space-lg);
  }

  .gr-blog-grid--2 { grid-template-columns: repeat(2, 1fr); }
  .gr-blog-grid--3 { grid-template-columns: repeat(3, 1fr); }
  .gr-blog-grid--4 { grid-template-columns: repeat(4, 1fr); }

  .gr-blog-card__media {
    display: block;
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .gr-blog-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--gr-transition-slow);
  }

  .gr-blog-card:hover .gr-blog-card__img {
    transform: scale(1.05);
  }

  .gr-blog-card__content {
    padding: var(--gr-space-lg);
  }

  .gr-blog-card__meta {
    display: flex;
    align-items: center;
    gap: var(--gr-space-md);
    margin-bottom: var(--gr-space-sm);
    font-size: var(--gr-body-xs);
  }

  .gr-blog-card__tag {
    font-family: var(--gr-font-heading);
    text-transform: uppercase;
    letter-spacing: var(--gr-tracking-wider);
    color: var(--gr-blood-red);
  }

  .gr-blog-card__date {
    color: var(--gr-text-muted);
  }

  .gr-blog-card__title {
    font-family: var(--gr-font-heading);
    font-size: var(--gr-heading-sm);
    text-transform: uppercase;
    letter-spacing: var(--gr-tracking-wide);
    line-height: var(--gr-leading-snug);
  }

  .gr-blog-card__title a {
    color: var(--gr-text-primary);
  }

  .gr-blog-card__title a:hover {
    color: var(--gr-blood-red);
  }

  .gr-blog-card__excerpt {
    color: var(--gr-text-secondary);
    font-size: var(--gr-body-sm);
    line-height: var(--gr-leading-normal);
    margin-top: var(--gr-space-sm);
  }

  @media (max-width: 768px) {
    .gr-blog-grid--3,
    .gr-blog-grid--4 {
      grid-template-columns: 1fr;
    }

    .gr-blog-grid__header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

{% schema %}
{
  "name": "GR Blog Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Recent Articles"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "posts_to_show",
      "label": "Posts to show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show excerpt",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View All button label",
      "default": "View All"
    }
  ],
  "presets": [
    {
      "name": "GR Blog Grid"
    }
  ]
}
{% endschema %}
