<div class="gr-section gr-reveal" {{ section.shopify_attributes }}>
  <div class="gr-container">
    {% if section.settings.heading != blank %}
      <h2 class="gr-heading gr-heading-xl gr-testimonials__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="gr-testimonials" data-gr-testimonials role="region" aria-roledescription="carousel" aria-label="{{ section.settings.heading | default: 'Testimonials' }}">
      <div class="gr-testimonials__track" data-gr-testimonials-track aria-live="polite" aria-atomic="true">
        {% for block in section.blocks %}
          <div class="gr-testimonials__slide{% if forloop.first %} is-active{% endif %}" data-gr-slide="{{ forloop.index0 }}" role="group" aria-roledescription="slide" aria-label="Testimonial {{ forloop.index }} of {{ section.blocks.size }}" {{ block.shopify_attributes }}>
            <blockquote class="gr-testimonials__quote">
              <svg class="gr-testimonials__quote-icon" width="40" height="32" viewBox="0 0 40 32" fill="none" aria-hidden="true">
                <path d="M0 32V19.2C0 8.53 5.87 2.13 17.6 0l1.6 3.2C11.73 5.07 8.27 9.6 8 16h8v16H0zm22.4 0V19.2C22.4 8.53 28.27 2.13 40 0l1.6 3.2C34.13 5.07 30.67 9.6 30.4 16h8v16H22.4z" fill="var(--gr-cta)" opacity="0.3"/>
              </svg>
              <p class="gr-testimonials__text">{{ block.settings.quote }}</p>
              <footer class="gr-testimonials__author">
                {% if block.settings.avatar %}
                  <div class="gr-testimonials__avatar">
                    {{ block.settings.avatar | image_url: width: 80 | image_tag:
                      loading: 'lazy',
                      widths: '80'
                    }}
                  </div>
                {% endif %}
                <div>
                  <cite class="gr-testimonials__name">{{ block.settings.author }}</cite>
                  {% if block.settings.location != blank %}
                    <span class="gr-testimonials__location">{{ block.settings.location }}</span>
                  {% endif %}
                </div>
              </footer>
            </blockquote>
          </div>
        {% endfor %}
      </div>

      {% if section.blocks.size > 1 %}
        <div class="gr-testimonials__dots">
          {% for block in section.blocks %}
            <button
              class="gr-testimonials__dot{% if forloop.first %} is-active{% endif %}"
              data-gr-dot="{{ forloop.index0 }}"
              aria-label="Go to testimonial {{ forloop.index }}"
            ></button>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

<style>
  .gr-testimonials__heading {
    text-align: center;
    margin-bottom: var(--gr-space-3xl);
  }

  .gr-testimonials {
    max-width: var(--gr-narrow-max);
    margin-inline: auto;
    position: relative;
  }

  .gr-testimonials__track {
    position: relative;
    overflow: hidden;
  }

  .gr-testimonials__slide {
    display: none;
    animation: gr-fade-in var(--gr-transition-slow) ease;
  }

  .gr-testimonials__slide.is-active {
    display: block;
  }

  .gr-testimonials__quote {
    text-align: center;
    margin: 0;
    padding: 0;
  }

  .gr-testimonials__quote-icon {
    margin-inline: auto;
    display: block;
    margin-bottom: var(--gr-space-lg);
  }

  .gr-testimonials__text {
    font-family: var(--gr-font-body);
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    line-height: var(--gr-leading-relaxed);
    color: var(--gr-text-primary);
    font-style: italic;
    margin-bottom: var(--gr-space-xl);
  }

  .gr-testimonials__author {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--gr-space-md);
  }

  .gr-testimonials__avatar {
    width: 48px;
    height: 48px;
    border-radius: var(--gr-radius-full);
    overflow: hidden;
    border: 2px solid var(--gr-border);
    flex-shrink: 0;
  }

  .gr-testimonials__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .gr-testimonials__name {
    display: block;
    font-family: var(--gr-font-heading);
    font-size: var(--gr-body-md);
    font-style: normal;
    letter-spacing: -0.02em;
    color: var(--gr-text-primary);
  }

  .gr-testimonials__location {
    display: block;
    font-size: var(--gr-body-sm);
    color: var(--gr-text-muted);
  }

  .gr-testimonials__dots {
    display: flex;
    justify-content: center;
    gap: var(--gr-space-sm);
    margin-top: var(--gr-space-2xl);
  }

  .gr-testimonials__dot {
    width: 10px;
    height: 10px;
    border-radius: var(--gr-radius-full);
    border: 1px solid var(--gr-border);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: all var(--gr-transition-fast);
  }

  .gr-testimonials__dot.is-active {
    background-color: var(--gr-cta);
    border-color: var(--gr-cta);
  }

  .gr-testimonials__dot:hover {
    border-color: var(--gr-cta);
  }
</style>

<script>
  (function() {
    document.querySelectorAll('[data-gr-testimonials]').forEach(function(container) {
      var slides = container.querySelectorAll('[data-gr-slide]');
      var dots = container.querySelectorAll('[data-gr-dot]');
      var current = 0;
      var autoplayInterval;
      var isPaused = false;

      function showSlide(index) {
        slides.forEach(function(s) { s.classList.remove('is-active'); });
        dots.forEach(function(d) {
          d.classList.remove('is-active');
          d.setAttribute('aria-selected', 'false');
        });
        slides[index].classList.add('is-active');
        if (dots[index]) {
          dots[index].classList.add('is-active');
          dots[index].setAttribute('aria-selected', 'true');
        }
        current = index;
      }

      dots.forEach(function(dot) {
        dot.addEventListener('click', function() {
          showSlide(parseInt(this.getAttribute('data-gr-dot')));
          resetAutoplay();
        });
      });

      function nextSlide() {
        if (!isPaused) {
          showSlide((current + 1) % slides.length);
        }
      }

      function resetAutoplay() {
        clearInterval(autoplayInterval);
        autoplayInterval = setInterval(nextSlide, 5000);
      }

      /* Pause autoplay on hover or focus within */
      container.addEventListener('mouseenter', function() { isPaused = true; });
      container.addEventListener('mouseleave', function() { isPaused = false; });
      container.addEventListener('focusin', function() { isPaused = true; });
      container.addEventListener('focusout', function() { isPaused = false; });

      /* Keyboard navigation on dot container */
      container.addEventListener('keydown', function(e) {
        if (e.key === 'ArrowLeft') {
          e.preventDefault();
          showSlide((current - 1 + slides.length) % slides.length);
          resetAutoplay();
        } else if (e.key === 'ArrowRight') {
          e.preventDefault();
          showSlide((current + 1) % slides.length);
          resetAutoplay();
        }
      });

      /* Respect reduced motion */
      var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)');
      if (slides.length > 1 && !prefersReduced.matches) {
        autoplayInterval = setInterval(nextSlide, 5000);
      }

      prefersReduced.addEventListener('change', function(e) {
        if (e.matches) {
          clearInterval(autoplayInterval);
        } else {
          resetAutoplay();
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "GR Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Riders Say"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "Best coffee I've ever had. Once you go GothRider, there's no going back."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author name",
          "default": "Frank G."
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location",
          "default": "Montreal, QC"
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Avatar"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "GR Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
