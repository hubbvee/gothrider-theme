<div class="gr-section gr-reveal" {{ section.shopify_attributes }}>
  <div class="gr-container">
    {% if section.settings.heading != blank %}
      <h2 class="gr-heading gr-heading-xl gr-image-mosaic__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {%- assign block_count = section.blocks.size -%}
    {%- assign is_odd = block_count | modulo: 2 -%}
    <div class="gr-image-mosaic{% if is_odd == 1 %} gr-image-mosaic--odd{% endif %}">
      {% for block in section.blocks %}
        <div class="gr-image-mosaic__item" {{ block.shopify_attributes }}>
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}" class="gr-image-mosaic__link">
          {% endif %}

          <div class="gr-image-mosaic__media">
            {% if block.settings.image %}
              {{ block.settings.image | image_url: width: 800 | image_tag:
                loading: 'lazy',
                sizes: '(min-width: 1024px) 33vw, 50vw',
                widths: '400, 600, 800',
                class: 'gr-image-mosaic__img'
              }}
            {% else %}
              {%- assign placeholder_index = forloop.index | minus: 1 | modulo: 2 | plus: 1 -%}
              {{ 'lifestyle-' | append: placeholder_index | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
          </div>

          {% if block.settings.caption != blank %}
            <div class="gr-image-mosaic__overlay">
              <span class="gr-image-mosaic__caption">{{ block.settings.caption }}</span>
            </div>
          {% endif %}

          {% if block.settings.link != blank %}
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<style>
  .gr-image-mosaic__heading {
    margin-bottom: var(--gr-space-2xl);
  }

  .gr-image-mosaic {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--gr-space-sm);
  }

  /* Odd count: first image spans full width */
  .gr-image-mosaic--odd .gr-image-mosaic__item:first-child {
    grid-column: 1 / -1;
  }

  .gr-image-mosaic__item {
    position: relative;
    overflow: hidden;
    background-color: var(--gr-black);
    border-radius: var(--gr-radius-md, 0.75rem);
  }

  .gr-image-mosaic__link {
    display: block;
    height: 100%;
  }

  .gr-image-mosaic__media {
    height: 100%;
    min-height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .gr-image-mosaic__media .placeholder-svg {
    width: 60%;
    height: auto;
    opacity: 0.15;
  }

  .gr-image-mosaic__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--gr-transition-slow);
  }

  .gr-image-mosaic__item:hover .gr-image-mosaic__img {
    transform: scale(1.05);
  }

  .gr-image-mosaic__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    padding: var(--gr-space-lg);
    background: linear-gradient(to top, rgba(0, 0, 0, 0.7), transparent 50%);
    opacity: 0;
    transition: opacity var(--gr-transition-base);
  }

  .gr-image-mosaic__item:hover .gr-image-mosaic__overlay {
    opacity: 1;
  }

  .gr-image-mosaic__caption {
    font-family: var(--gr-font-heading);
    font-size: var(--gr-heading-sm);
    letter-spacing: -0.02em;
    color: var(--gr-text-primary);
  }

  @media (max-width: 768px) {
    .gr-image-mosaic__overlay {
      opacity: 1;
    }
  }
</style>

{% schema %}
{
  "name": "GR Image Mosaic",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "GR Image Mosaic",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
