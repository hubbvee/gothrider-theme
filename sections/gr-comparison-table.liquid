<div class="gr-section gr-reveal" {{ section.shopify_attributes }}>
  <div class="gr-container">
    <div class="gr-comparison__header">
      {% if section.settings.subheading != blank %}
        <p class="gr-comparison__subheading">{{ section.settings.subheading }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="gr-heading gr-heading-xl gr-comparison__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.description != blank %}
        <div class="gr-comparison__description">{{ section.settings.description }}</div>
      {% endif %}
    </div>

    {%- assign product_columns = section.blocks | where: 'type', 'product_column' -%}
    {%- assign col_count = product_columns.size -%}

    <div class="gr-comparison" style="--gr-comparison-cols: {{ col_count }}">
      {%- comment -%} Product cards row {%- endcomment -%}
      <div class="gr-comparison__products gr-comparison__grid--{{ col_count }}">
        <div class="gr-comparison__label-spacer"></div>
        {% for block in product_columns %}
          <div class="gr-comparison__product-card" {{ block.shopify_attributes }}>
            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}" class="gr-comparison__product-link">
            {% endif %}
            {% if block.settings.image %}
              <div class="gr-comparison__product-img">
                {{ block.settings.image | image_url: width: 200 | image_tag: loading: 'lazy', widths: '120, 200' }}
              </div>
            {% else %}
              <div class="gr-comparison__product-img gr-comparison__product-img--placeholder">
                {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {% endif %}
            {% if block.settings.link != blank %}
              </a>
            {% endif %}
            <div class="gr-comparison__product-info">
              {% if block.settings.link != blank %}
                <a href="{{ block.settings.link }}" class="gr-comparison__product-name-link">{{ block.settings.name }}</a>
              {% else %}
                <span class="gr-comparison__product-name">{{ block.settings.name }}</span>
              {% endif %}
              {% if block.settings.price != blank %}
                <span class="gr-comparison__product-price">{{ block.settings.price }}</span>
              {% endif %}
              {% if block.settings.link != blank %}
                <a href="{{ block.settings.link }}" class="gr-comparison__view-btn">View</a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>

      {%- comment -%} Feature rows {%- endcomment -%}
      {%- assign outputted_count = 0 -%}
      {%- assign row_index = 0 -%}
      {% for block in section.blocks %}
        {% if block.type == 'row' %}
          {%- assign row_index = row_index | plus: 1 -%}
          {%- assign outputted_count = outputted_count | plus: 1 -%}
          <div class="gr-comparison__row gr-comparison__grid--{{ col_count }}"
               {% if outputted_count > section.settings.max_rows %}hidden{% endif %}
               {{ block.shopify_attributes }}>
            <div class="gr-comparison__feature">{{ block.settings.feature }}</div>
            {% for product in product_columns %}
              {%- assign value_key = 'value_row_' | append: row_index -%}
              {%- assign cell_value = product.settings[value_key] -%}
              <div class="gr-comparison__value" data-product="{{ product.settings.name | escape }}">
                {{ cell_value | default: '—' }}
              </div>
            {% endfor %}
          </div>
        {% endif %}
      {% endfor %}

      {%- if outputted_count > section.settings.max_rows -%}
        <div class="gr-comparison__toggle">
          <button class="gr-comparison__toggle-btn" aria-expanded="false">
            <span class="gr-comparison__toggle-text">{{ section.settings.view_all_text }}</span>
            <svg class="gr-comparison__toggle-icon" width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  .gr-comparison__header {
    text-align: center;
    margin-bottom: var(--gr-space-3xl);
  }

  .gr-comparison__subheading {
    font-family: var(--gr-font-heading);
    font-size: var(--gr-body-sm);
    text-transform: uppercase;
    letter-spacing: var(--gr-tracking-widest);
    color: var(--gr-cta);
    margin-bottom: var(--gr-space-md);
  }

  .gr-comparison__heading {
    margin-bottom: var(--gr-space-lg);
  }

  .gr-comparison__description {
    max-width: var(--gr-narrow-max);
    margin-inline: auto;
    color: var(--gr-text-secondary);
    line-height: var(--gr-leading-relaxed);
    font-size: var(--gr-body-md);
  }

  .gr-comparison {
    background-color: var(--gr-surface-elevated);
    border-radius: var(--gr-radius-md, 0.75rem);
    padding: var(--gr-space-xl);
    overflow-x: auto;
  }

  .gr-comparison__products {
    display: grid;
    gap: var(--gr-space-md);
    padding-bottom: var(--gr-space-xl);
    border-bottom: 1px solid var(--gr-border-subtle);
    margin-bottom: var(--gr-space-md);
  }

  .gr-comparison__grid--2 { grid-template-columns: 1fr repeat(2, 1fr); }
  .gr-comparison__grid--3 { grid-template-columns: 1fr repeat(3, 1fr); }

  .gr-comparison__label-spacer {
    /* Empty first column for alignment with feature rows */
  }

  .gr-comparison__product-card {
    text-align: center;
  }

  .gr-comparison__product-link {
    display: block;
    text-decoration: none;
  }

  .gr-comparison__product-img {
    width: 140px;
    height: 140px;
    margin: 0 auto var(--gr-space-sm);
    border-radius: var(--gr-radius-md);
    overflow: hidden;
    background-color: var(--gr-surface-elevated);
  }

  .gr-comparison__product-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .gr-comparison__product-img--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .gr-comparison__product-img--placeholder .placeholder-svg {
    width: 60%;
    opacity: 0.15;
  }

  .gr-comparison__product-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--gr-space-xs);
  }

  .gr-comparison__product-name,
  .gr-comparison__product-name-link {
    font-family: var(--gr-font-heading);
    font-size: var(--gr-heading-sm);
    letter-spacing: -0.02em;
    color: var(--gr-text-primary);
    text-decoration: none;
  }

  .gr-comparison__product-name-link:hover {
    color: var(--gr-cta);
  }

  .gr-comparison__product-price {
    font-size: var(--gr-body-sm);
    color: var(--gr-text-secondary);
  }

  .gr-comparison__view-btn {
    display: inline-block;
    margin-top: var(--gr-space-xs);
    padding: var(--gr-space-xs) var(--gr-space-md);
    font-family: var(--gr-font-heading);
    font-size: var(--gr-body-sm);
    color: var(--gr-text-primary);
    border: 1px solid var(--gr-border);
    border-radius: var(--gr-radius-button);
    text-decoration: none;
    transition: opacity var(--gr-transition-fast);
  }

  .gr-comparison__view-btn:hover {
    opacity: 0.85;
    color: var(--gr-text-primary);
  }

  .gr-comparison__row {
    display: grid;
    gap: var(--gr-space-md);
    padding: var(--gr-space-lg) 0;
    border-bottom: 1px solid var(--gr-border, var(--gr-border-subtle, rgba(255,255,255,.1)));
    align-items: center;
  }

  .gr-comparison__row:last-child {
    border-bottom: none;
  }

  .gr-comparison__feature {
    font-weight: var(--gr-weight-semibold);
    color: var(--gr-text-secondary);
    font-size: var(--gr-body-md);
  }

  .gr-comparison__value {
    text-align: center;
    color: var(--gr-text-primary);
    font-size: var(--gr-body-md);
    background: var(--gr-surface-base, #1a1a1a);
    border-radius: 999px;
    padding: var(--gr-space-xs) var(--gr-space-md);
  }

  /* Toggle button */
  .gr-comparison__toggle {
    text-align: center;
    border-top: 1px solid var(--gr-border-subtle);
    padding: var(--gr-space-md) 0;
  }

  .gr-comparison__toggle-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--gr-space-xs);
    background: none;
    border: none;
    color: var(--gr-text-primary);
    font-family: var(--gr-font-heading);
    font-size: var(--gr-body-sm);
    cursor: pointer;
    transition: opacity var(--gr-transition-fast);
  }

  .gr-comparison__toggle-btn:hover { opacity: 0.7; }

  .gr-comparison__toggle-icon {
    transition: transform var(--gr-transition-fast);
  }

  .gr-comparison[data-expanded] .gr-comparison__toggle-icon {
    transform: rotate(180deg);
  }

  @media (max-width: 768px) {
    /* Edge-to-edge bleed for full-width swipe */
    .gr-comparison {
      margin-inline: calc(-1 * var(--gr-gutter));
      padding-inline: var(--gr-gutter);
      overflow: auto hidden;
      scrollbar-width: none;
      scroll-snap-type: x mandatory;
      overscroll-behavior-x: contain;
    }

    .gr-comparison::-webkit-scrollbar { display: none; }

    /* Hide the empty label spacer in product row */
    .gr-comparison__label-spacer { display: none; }

    /* Product row: only product columns, fixed width */
    .gr-comparison__products {
      grid-template-columns: repeat(var(--gr-comparison-cols), 150px);
      width: max-content;
      min-width: 100%;
    }

    /* Feature rows: wide enough for grid tracks so sticky has room */
    .gr-comparison__row {
      grid-template-columns: repeat(var(--gr-comparison-cols), 150px);
      width: max-content;
      min-width: 100%;
      padding: var(--gr-space-md) 0;
      border-bottom-color: var(--gr-border);
    }

    /* Feature label: sticky at left edge, spans full width above values */
    .gr-comparison__feature {
      grid-column: 1 / -1;
      position: sticky;
      left: 0;
      max-width: calc(100vw - 2 * var(--gr-gutter));
      background: var(--gr-surface-elevated);
      padding-bottom: var(--gr-space-xs);
      font-size: var(--gr-body-sm);
      z-index: 1;
    }

    /* Values drop to row 2, under the label — filled pill style */
    .gr-comparison__value {
      grid-row: 2;
      background: var(--gr-surface-base, #1a1a1a);
      border-radius: 999px;
      padding: var(--gr-space-xs) var(--gr-space-md);
      font-size: var(--gr-body-sm);
    }

    /* Show product name above each value */
    .gr-comparison__value::before {
      content: attr(data-product);
      display: block;
      font-size: 0.65rem;
      color: var(--gr-text-secondary);
      margin-bottom: 2px;
    }

    /* Smaller product images */
    .gr-comparison__product-img {
      width: 70px;
      height: 70px;
    }

    /* Smaller product names */
    .gr-comparison__product-name,
    .gr-comparison__product-name-link {
      font-size: var(--gr-body-sm);
    }
  }
</style>

<script>
  (function() {
    var section = document.querySelector('#shopify-section-{{ section.id }}');
    if (!section) return;
    var btn = section.querySelector('.gr-comparison__toggle-btn');
    if (!btn) return;
    var comparison = section.querySelector('.gr-comparison');
    var viewMore = {{ section.settings.view_all_text | json }};
    var viewLess = {{ section.settings.view_less_text | json }};

    btn.addEventListener('click', function() {
      var expanded = comparison.hasAttribute('data-expanded');

      if (expanded) {
        var max = {{ section.settings.max_rows }};
        comparison.querySelectorAll('.gr-comparison__row').forEach(function(row, i) {
          if (i >= max) row.hidden = true;
        });
        comparison.removeAttribute('data-expanded');
        btn.querySelector('.gr-comparison__toggle-text').textContent = viewMore;
        btn.setAttribute('aria-expanded', 'false');
      } else {
        comparison.querySelectorAll('.gr-comparison__row[hidden]').forEach(function(row) {
          row.hidden = false;
        });
        comparison.setAttribute('data-expanded', '');
        btn.querySelector('.gr-comparison__toggle-text').textContent = viewLess;
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  })();
</script>

{% schema %}
{
  "name": "GR Comparison Table",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Compare"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Compare Our Coffees"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "feature_label",
      "label": "Feature column label",
      "default": "Feature"
    },
    {
      "type": "range",
      "id": "max_rows",
      "min": 1,
      "max": 20,
      "label": "Rows shown by default",
      "default": 5
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View all text",
      "default": "View all"
    },
    {
      "type": "text",
      "id": "view_less_text",
      "label": "View less text",
      "default": "View less"
    }
  ],
  "blocks": [
    {
      "type": "product_column",
      "name": "Product Column",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Product name",
          "default": "Gasoline"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Product link"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price text",
          "info": "e.g. From $24.99 CAD"
        },
        { "type": "text", "id": "value_row_1", "label": "Row 1 value" },
        { "type": "text", "id": "value_row_2", "label": "Row 2 value" },
        { "type": "text", "id": "value_row_3", "label": "Row 3 value" },
        { "type": "text", "id": "value_row_4", "label": "Row 4 value" },
        { "type": "text", "id": "value_row_5", "label": "Row 5 value" },
        { "type": "text", "id": "value_row_6", "label": "Row 6 value" },
        { "type": "text", "id": "value_row_7", "label": "Row 7 value" },
        { "type": "text", "id": "value_row_8", "label": "Row 8 value" },
        { "type": "text", "id": "value_row_9", "label": "Row 9 value" },
        { "type": "text", "id": "value_row_10", "label": "Row 10 value" }
      ]
    },
    {
      "type": "row",
      "name": "Comparison Row",
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "label": "Feature name",
          "default": "Roast Level"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "GR Comparison Table",
      "blocks": [
        { "type": "product_column" },
        { "type": "product_column" },
        { "type": "row" },
        { "type": "row" },
        { "type": "row" },
        { "type": "row" }
      ]
    }
  ]
}
{% endschema %}
