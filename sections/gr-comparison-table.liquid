<div class="gr-section gr-reveal" {{ section.shopify_attributes }}>
  <div class="gr-container">
    {% if section.settings.heading != blank %}
      <h2 class="gr-heading gr-heading-xl gr-comparison__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="gr-comparison__wrapper">
      <table class="gr-comparison__table">
        <thead>
          <tr>
            <th class="gr-comparison__feature-header">{{ section.settings.feature_label | default: 'Feature' }}</th>
            {% for block in section.blocks %}
              {% if block.type == 'product_column' %}
                <th class="gr-comparison__product-header" {{ block.shopify_attributes }}>
                  {% if block.settings.image %}
                    <div class="gr-comparison__product-img">
                      {{ block.settings.image | image_url: width: 120 | image_tag: loading: 'lazy', widths: '120' }}
                    </div>
                  {% endif %}
                  <span>{{ block.settings.name }}</span>
                </th>
              {% endif %}
            {% endfor %}
          </tr>
        </thead>
        <tbody>
          {% for block in section.blocks %}
            {% if block.type == 'row' %}
              <tr {{ block.shopify_attributes }}>
                <td class="gr-comparison__feature">{{ block.settings.feature }}</td>
                <td class="gr-comparison__value">{{ block.settings.value_1 }}</td>
                {% if block.settings.value_2 != blank %}
                  <td class="gr-comparison__value">{{ block.settings.value_2 }}</td>
                {% endif %}
                {% if block.settings.value_3 != blank %}
                  <td class="gr-comparison__value">{{ block.settings.value_3 }}</td>
                {% endif %}
              </tr>
            {% endif %}
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</div>

<style>
  .gr-comparison__heading {
    text-align: center;
    margin-bottom: var(--gr-space-3xl);
  }

  .gr-comparison__wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .gr-comparison__table {
    width: 100%;
    border-collapse: collapse;
    min-width: 500px;
  }

  .gr-comparison__table th,
  .gr-comparison__table td {
    padding: var(--gr-space-md) var(--gr-space-lg);
    text-align: center;
    border-bottom: 1px solid var(--gr-border-subtle);
  }

  .gr-comparison__feature-header {
    text-align: left;
    font-family: var(--gr-font-heading);
    font-size: var(--gr-body-sm);
    text-transform: uppercase;
    letter-spacing: var(--gr-tracking-wider);
    color: var(--gr-text-muted);
  }

  .gr-comparison__product-header {
    font-family: var(--gr-font-heading);
    font-size: var(--gr-heading-sm);
    text-transform: uppercase;
    letter-spacing: var(--gr-tracking-wide);
    color: var(--gr-text-primary);
    padding-bottom: var(--gr-space-lg);
  }

  .gr-comparison__product-img {
    width: 80px;
    height: 80px;
    margin: 0 auto var(--gr-space-sm);
    border-radius: var(--gr-radius-md);
    overflow: hidden;
    background-color: var(--gr-surface);
  }

  .gr-comparison__product-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .gr-comparison__feature {
    text-align: left;
    font-weight: var(--gr-weight-medium);
    color: var(--gr-text-secondary);
  }

  .gr-comparison__value {
    color: var(--gr-bone-white);
    font-size: var(--gr-body-sm);
  }

  .gr-comparison__table tbody tr:hover {
    background-color: var(--gr-surface);
  }
</style>

{% schema %}
{
  "name": "GR Comparison Table",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Compare Our Coffees"
    },
    {
      "type": "text",
      "id": "feature_label",
      "label": "Feature column label",
      "default": "Feature"
    }
  ],
  "blocks": [
    {
      "type": "product_column",
      "name": "Product Column",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Product name",
          "default": "Gasoline"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product image"
        }
      ]
    },
    {
      "type": "row",
      "name": "Comparison Row",
      "settings": [
        {
          "type": "text",
          "id": "feature",
          "label": "Feature name",
          "default": "Roast Level"
        },
        {
          "type": "text",
          "id": "value_1",
          "label": "Product 1 value",
          "default": "Dark"
        },
        {
          "type": "text",
          "id": "value_2",
          "label": "Product 2 value"
        },
        {
          "type": "text",
          "id": "value_3",
          "label": "Product 3 value"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "GR Comparison Table",
      "blocks": [
        { "type": "product_column" },
        { "type": "product_column" },
        { "type": "row" },
        { "type": "row" },
        { "type": "row" },
        { "type": "row" }
      ]
    }
  ]
}
{% endschema %}
