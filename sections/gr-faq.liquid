<div class="gr-section gr-section--darker gr-reveal" {{ section.shopify_attributes }}>
  <div class="gr-container">
    <div class="gr-faq__layout gr-faq__layout--{{ section.settings.layout }}">
      <div class="gr-faq__header">
        {% if section.settings.heading != blank %}
          <h2 class="gr-heading gr-heading-xl">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subtext != blank %}
          <p class="gr-faq__subtext">{{ section.settings.subtext }}</p>
        {% endif %}
      </div>

      <div class="gr-faq__list">
        {% for block in section.blocks %}
          <details class="gr-faq__item" {{ block.shopify_attributes }}>
            <summary class="gr-faq__question">
              <span>{{ block.settings.question }}</span>
              <svg class="gr-faq__icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </summary>
            <div class="gr-faq__answer">
              {{ block.settings.answer }}
            </div>
          </details>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<style>
  .gr-faq__layout--side-by-side {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--gr-space-3xl);
    align-items: start;
  }

  .gr-faq__layout--stacked .gr-faq__header {
    text-align: center;
    margin-bottom: var(--gr-space-3xl);
    max-width: var(--gr-narrow-max);
    margin-inline: auto;
  }

  .gr-faq__subtext {
    color: var(--gr-text-secondary);
    margin-top: var(--gr-space-md);
    line-height: var(--gr-leading-relaxed);
  }

  .gr-faq__list {
    max-width: var(--gr-narrow-max);
  }

  .gr-faq__layout--stacked .gr-faq__list {
    margin-inline: auto;
  }

  .gr-faq__item {
    border-bottom: 1px solid var(--gr-border-subtle);
  }

  .gr-faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--gr-space-md);
    padding: var(--gr-space-lg) 0;
    cursor: pointer;
    font-family: var(--gr-font-heading);
    font-size: var(--gr-heading-sm);
    letter-spacing: -0.02em;
    color: var(--gr-text-primary);
    list-style: none;
  }

  .gr-faq__question::-webkit-details-marker {
    display: none;
  }

  .gr-faq__question::marker {
    content: '';
  }

  .gr-faq__icon {
    flex-shrink: 0;
    transition: transform var(--gr-transition-base);
    color: var(--gr-text-muted);
  }

  details[open] .gr-faq__icon {
    transform: rotate(180deg);
  }

  .gr-faq__answer {
    padding-bottom: var(--gr-space-lg);
    color: var(--gr-text-secondary);
    line-height: var(--gr-leading-relaxed);
    font-size: var(--gr-body-md);
  }

  .gr-faq__question:hover {
    color: var(--gr-cta);
  }

  @media (max-width: 768px) {
    .gr-faq__layout--side-by-side {
      grid-template-columns: 1fr;
    }
  }
</style>

{% comment %} ── FAQPage structured data for SEO ── {% endcomment %}
{% if section.blocks.size > 0 %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {%- for block in section.blocks -%}
        {
          "@type": "Question",
          "name": {{ block.settings.question | json }},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": {{ block.settings.answer | strip_html | json }}
          }
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
  }
  </script>
{% endif %}

{% schema %}
{
  "name": "GR FAQ",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Have a Question?"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "stacked", "label": "Stacked (centered)" },
        { "value": "side-by-side", "label": "Side by side" }
      ],
      "default": "stacked"
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How long does shipping take?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>We ship within 24 hours on business days. Standard shipping takes 3-5 business days within Canada and 5-10 business days to the US.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "GR FAQ",
      "blocks": [
        { "type": "question" },
        { "type": "question" },
        { "type": "question" },
        { "type": "question" },
        { "type": "question" }
      ]
    }
  ]
}
{% endschema %}
