<div class="gr-section gr-reveal" {{ section.shopify_attributes }}>
  <div class="gr-container">
    {% if section.settings.heading != blank %}
      <h2 class="gr-heading gr-heading-xl gr-collection-list__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="gr-collection-list gr-collection-list--{{ section.settings.columns }}">
      {% for block in section.blocks %}
        {%- assign collection = block.settings.collection -%}
        <a href="{{ collection.url | default: '#' }}" class="gr-collection-list__item gr-card" {{ block.shopify_attributes }}>
          <div class="gr-collection-list__media">
            {% if collection.image %}
              {{ collection.image | image_url: width: 600 | image_tag:
                loading: 'lazy',
                sizes: '(min-width: 1024px) 25vw, 50vw',
                widths: '300, 400, 600',
                class: 'gr-collection-list__img'
              }}
            {% elsif block.settings.image %}
              {{ block.settings.image | image_url: width: 600 | image_tag:
                loading: 'lazy',
                sizes: '(min-width: 1024px) 25vw, 50vw',
                widths: '300, 400, 600',
                class: 'gr-collection-list__img'
              }}
            {% else %}
              {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
          </div>
          <div class="gr-collection-list__info">
            <h3 class="gr-collection-list__title">{{ collection.title | default: block.settings.title | default: 'Collection' }}</h3>
            {% if section.settings.show_count and collection %}
              <span class="gr-collection-list__count">{{ collection.products_count }} {{ 'collections.general.items' | t | default: 'products' }}</span>
            {% endif %}
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</div>

<style>
  .gr-collection-list__heading {
    margin-bottom: var(--gr-space-2xl);
    text-align: center;
  }

  .gr-collection-list {
    display: grid;
    gap: var(--gr-space-lg);
  }

  .gr-collection-list--2 { grid-template-columns: repeat(2, 1fr); }
  .gr-collection-list--3 { grid-template-columns: repeat(3, 1fr); }
  .gr-collection-list--4 { grid-template-columns: repeat(4, 1fr); }

  .gr-collection-list__item {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .gr-collection-list__item:hover {
    color: inherit;
  }

  .gr-collection-list__media {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background-color: var(--gr-surface);
    border-radius: var(--gr-radius-md, 0.75rem);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .gr-collection-list__media .placeholder-svg {
    width: 60%;
    height: auto;
    opacity: 0.15;
  }

  .gr-collection-list__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--gr-transition-slow);
  }

  .gr-collection-list__item:hover .gr-collection-list__img {
    transform: scale(1.05);
  }

  .gr-collection-list__info {
    padding: var(--gr-space-md);
    text-align: center;
  }

  .gr-collection-list__title {
    font-family: var(--gr-font-heading);
    font-size: var(--gr-heading-sm);
    letter-spacing: -0.02em;
    margin-bottom: var(--gr-space-xs);
  }

  .gr-collection-list__count {
    font-size: var(--gr-body-sm);
    color: var(--gr-text-muted);
  }

  @media (max-width: 768px) {
    .gr-collection-list--3,
    .gr-collection-list--4 {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

{% schema %}
{
  "name": "GR Collection List",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop By Category"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    },
    {
      "type": "checkbox",
      "id": "show_count",
      "label": "Show product count",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom title (optional)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "GR Collection List",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
