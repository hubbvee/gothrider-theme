{% assign content_slides = section.blocks | where: "type", "content_slide" %}
{% assign has_carousel = false %}
{% if content_slides.size > 0 %}{% assign has_carousel = true %}{% endif %}

<style>
  #shopify-section-{{ section.id }} {
    --gr-image-rotation: {{ section.settings.image_rotation | default: 0 }}deg;
    {% if section.settings.image_glow %}
      --gr-image-glow: drop-shadow(0 0 20px {{ section.settings.glow_color | default: '#FF5500' }}80)
                        drop-shadow(0 0 60px {{ section.settings.glow_color | default: '#FF5500' }}40);
    {% else %}
      --gr-image-glow: none;
    {% endif %}
  }
</style>

<div class="gr-section gr-reveal" {{ section.shopify_attributes }}>
  <div class="gr-container">
    <div class="gr-brand-story gr-brand-story--{{ section.settings.layout }}">
      <div class="gr-brand-story__media">
        {% for block in section.blocks %}
          {% if block.type == 'image' %}
            <div class="gr-brand-story__image" {{ block.shopify_attributes }}>
              {% if block.settings.image %}
                {{ block.settings.image | image_url: width: 800 | image_tag:
                  loading: 'lazy',
                  sizes: '(min-width: 1024px) 40vw, 100vw',
                  widths: '400, 600, 800',
                  class: 'gr-brand-story__img'
                }}
              {% else %}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <div class="gr-brand-story__content" {% if has_carousel %}data-gr-brand-carousel{% endif %}>
        {% if has_carousel %}
          <div class="gr-brand-story__carousel-track">
            {% for block in content_slides %}
              <div class="gr-brand-story__slide{% if forloop.first %} is-active{% endif %}"
                   data-gr-slide="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
                {% if block.settings.subheading != blank %}
                  <p class="gr-brand-story__subheading">{{ block.settings.subheading }}</p>
                {% endif %}
                {% if block.settings.heading != blank %}
                  <h2 class="gr-heading gr-heading-xl gr-brand-story__title">{{ block.settings.heading }}</h2>
                {% endif %}
                {% if block.settings.text != blank %}
                  <div class="gr-brand-story__text">{{ block.settings.text }}</div>
                {% endif %}
                {% if block.settings.button_label != blank %}
                  <div class="gr-brand-story__cta">
                    <a href="{{ block.settings.button_link }}" class="gr-btn gr-btn--secondary">
                      {{ block.settings.button_label }}
                    </a>
                  </div>
                {% endif %}
              </div>
            {% endfor %}
          </div>

          {% if content_slides.size > 1 %}
            <div class="gr-brand-story__nav">
              <button class="gr-brand-story__arrow gr-brand-story__arrow--prev" data-gr-prev aria-label="Previous slide">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <button class="gr-brand-story__arrow gr-brand-story__arrow--next" data-gr-next aria-label="Next slide">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>
          {% endif %}

        {% else %}
          {%- comment -%} Existing individual block rendering (backward compatible) {%- endcomment -%}
          {% for block in section.blocks %}
            {% if block.type == 'heading' %}
              <h2 class="gr-heading gr-heading-xl gr-brand-story__title" {{ block.shopify_attributes }}>
                {{ block.settings.heading }}
              </h2>
            {% elsif block.type == 'subheading' %}
              <p class="gr-brand-story__subheading" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </p>
            {% elsif block.type == 'text' %}
              <div class="gr-brand-story__text" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </div>
            {% elsif block.type == 'button' %}
              <div class="gr-brand-story__cta" {{ block.shopify_attributes }}>
                <a href="{{ block.settings.link }}" class="gr-btn gr-btn--{{ block.settings.style }}">
                  {{ block.settings.label }}
                </a>
              </div>
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>
</div>

<style>
  .gr-brand-story {
    display: grid;
    gap: var(--gr-space-3xl);
    align-items: center;
  }

  .gr-brand-story--image-left {
    grid-template-columns: 1fr 1fr;
  }

  .gr-brand-story--image-right {
    grid-template-columns: 1fr 1fr;
  }

  .gr-brand-story--image-right .gr-brand-story__media {
    order: 2;
  }

  .gr-brand-story__media {
    display: grid;
    grid-template-columns: 3fr 4fr;
    grid-template-rows: 1fr;
    gap: 0;
    align-items: center;
    position: relative;
    min-height: 500px;
  }

  .gr-brand-story__media:has(> :only-child) {
    grid-template-columns: 1fr;
  }

  .gr-brand-story__image {
    overflow: hidden;
    border: 1px solid var(--gr-border-subtle);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--gr-surface);
    max-height: 520px;
    transform: rotate(var(--gr-image-rotation, 0deg));
    filter: var(--gr-image-glow, none);
    transition: transform var(--gr-transition-slow, 0.5s), filter var(--gr-transition-slow, 0.5s);
  }

  .gr-brand-story__image:nth-child(1) {
    z-index: 1;
    align-self: end;
    margin-bottom: 1rem;
  }

  .gr-brand-story__image:nth-child(2) {
    z-index: 2;
    margin-left: -2rem;
    align-self: start;
  }

  .gr-brand-story__image .placeholder-svg {
    width: 60%;
    height: auto;
    aspect-ratio: 3 / 4;
    opacity: 0.15;
  }

  .gr-brand-story__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 4 / 5;
  }

  .gr-brand-story__subheading {
    font-family: var(--gr-font-heading);
    font-size: var(--gr-body-sm);
    text-transform: uppercase;
    letter-spacing: var(--gr-tracking-widest);
    color: var(--gr-cta);
    margin-bottom: var(--gr-space-md);
  }

  .gr-brand-story__title {
    margin-bottom: var(--gr-space-lg);
  }

  .gr-brand-story__text {
    font-size: var(--gr-body-lg);
    line-height: var(--gr-leading-relaxed);
    color: var(--gr-text-secondary);
    margin-bottom: var(--gr-space-lg);
  }

  .gr-brand-story__cta {
    margin-top: var(--gr-space-md);
  }

  /* Carousel slide styles */
  .gr-brand-story__slide {
    display: none;
    animation: gr-brand-fade-in var(--gr-transition-slow, 0.5s) ease;
  }

  .gr-brand-story__slide.is-active {
    display: block;
  }

  @keyframes gr-brand-fade-in {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .gr-brand-story__nav {
    display: flex;
    gap: var(--gr-space-md);
    margin-top: var(--gr-space-xl);
  }

  .gr-brand-story__arrow {
    width: 40px;
    height: 40px;
    border-radius: var(--gr-radius-full, 50%);
    border: 1px solid var(--gr-border, rgba(255,255,255,0.2));
    background: transparent;
    color: var(--gr-text-primary);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--gr-transition-fast, 0.2s);
  }

  .gr-brand-story__arrow:hover {
    border-color: var(--gr-cta);
    color: var(--gr-cta);
  }

  @media (max-width: 768px) {
    .gr-brand-story--image-left,
    .gr-brand-story--image-right {
      grid-template-columns: 1fr;
    }

    .gr-brand-story--image-right .gr-brand-story__media {
      order: 0;
    }

    .gr-brand-story__media {
      grid-template-columns: 1fr 1fr;
      min-height: auto;
    }

    .gr-brand-story__image:nth-child(2) {
      margin-left: -1rem;
    }
  }
</style>

<script>
  (function() {
    document.querySelectorAll('[data-gr-brand-carousel]').forEach(function(container) {
      var slides = container.querySelectorAll('[data-gr-slide]');
      var prevBtn = container.querySelector('[data-gr-prev]');
      var nextBtn = container.querySelector('[data-gr-next]');
      var current = 0;

      if (slides.length < 2) return;

      function showSlide(index) {
        slides.forEach(function(s) { s.classList.remove('is-active'); });
        slides[index].classList.add('is-active');
        current = index;
      }

      if (prevBtn) prevBtn.addEventListener('click', function() {
        showSlide((current - 1 + slides.length) % slides.length);
      });

      if (nextBtn) nextBtn.addEventListener('click', function() {
        showSlide((current + 1) % slides.length);
      });

      /* Keyboard support */
      container.addEventListener('keydown', function(e) {
        if (e.key === 'ArrowLeft') {
          e.preventDefault();
          showSlide((current - 1 + slides.length) % slides.length);
        }
        if (e.key === 'ArrowRight') {
          e.preventDefault();
          showSlide((current + 1) % slides.length);
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "GR Brand Story",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "image-left", "label": "Images Left, Text Right" },
        { "value": "image-right", "label": "Images Right, Text Left" }
      ],
      "default": "image-left"
    },
    {
      "type": "header",
      "content": "Image effects"
    },
    {
      "type": "range",
      "id": "image_rotation",
      "min": -15,
      "max": 15,
      "step": 1,
      "unit": "deg",
      "label": "Image rotation",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "image_glow",
      "label": "Enable image glow",
      "default": false
    },
    {
      "type": "color",
      "id": "glow_color",
      "label": "Glow color",
      "default": "#FF5500"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    },
    {
      "type": "subheading",
      "name": "Subheading",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Subheading",
          "default": "Our Story"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Expressing Our Rebel Instinct"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Born from a love of dark roasts and darker aesthetics, GothRider is for those who were told to tone it down — and turned it up instead.</p>"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Learn More"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "select",
          "id": "style",
          "label": "Style",
          "options": [
            { "value": "primary", "label": "Primary" },
            { "value": "secondary", "label": "Secondary" },
            { "value": "ghost", "label": "Ghost" }
          ],
          "default": "secondary"
        }
      ]
    },
    {
      "type": "content_slide",
      "name": "Content Slide",
      "settings": [
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "GR Brand Story",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "subheading" },
        { "type": "heading" },
        { "type": "text" },
        { "type": "button" }
      ]
    }
  ]
}
{% endschema %}
