{% stylesheet %}
  .gr-hero-wrapper {
    margin: 0;
    padding: 0;
  }

  .gr-hero {
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .gr-hero--full { min-height: 100vh; }
  .gr-hero--medium { min-height: 60vh; }

  .gr-hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .gr-hero__media picture {
    display: block;
    width: 100%;
    height: 100%;
  }

  .gr-hero__media img,
  .gr-hero__media video {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: var(--gr-hero-fit, cover);
    object-position: var(--gr-hero-focus, center center);
  }

  .gr-hero__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .gr-hero__overlay--dark {
    background: linear-gradient(
      to bottom,
      rgba(10, 10, 10, 0.3),
      rgba(10, 10, 10, 0.8)
    );
  }

  .gr-hero__overlay--darker {
    background: linear-gradient(
      to bottom,
      rgba(10, 10, 10, 0.5),
      rgba(10, 10, 10, 0.9)
    );
  }

  .gr-hero__overlay--blood {
    background: linear-gradient(
      to bottom,
      rgba(139, 0, 0, 0.2),
      rgba(10, 10, 10, 0.85)
    );
  }

  .gr-hero__overlay--custom {
    background: linear-gradient(
      to bottom,
      var(--gr-hero-overlay-start),
      var(--gr-hero-overlay-end)
    );
  }

  .gr-hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: var(--gr-space-xl);
    max-width: var(--gr-content-max);
  }

  .gr-hero__title {
    font-size: var(--gr-heading-xxl);
    margin-bottom: var(--gr-space-md);
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
  }

  .gr-hero__subtitle {
    font-family: var(--gr-font-body);
    font-size: var(--gr-body-lg);
    color: var(--gr-bone-white-muted);
    margin-bottom: var(--gr-space-xl);
    font-weight: var(--gr-weight-regular);
    text-transform: none;
    letter-spacing: var(--gr-tracking-normal);
    line-height: var(--gr-leading-normal);
  }

  .gr-hero__actions {
    display: flex;
    gap: var(--gr-space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .gr-hero__media {
      background-color: var(--gr-black, #0A0A0A);
    }

    .gr-hero__content { padding: var(--gr-space-lg); }
    .gr-hero__actions { flex-direction: column; align-items: center; }
  }
{% endstylesheet %}

<style>
  #shopify-section-{{ section.id }} .gr-hero {
    --gr-hero-focus: {{ section.settings.image_focus }};
    --gr-hero-fit: cover;
  }

  /* Full-screen hero: sit below header, fill remaining viewport */
  #shopify-section-{{ section.id }}:has(.gr-hero--full) {
    margin-top: 61px !important;
  }

  #shopify-section-{{ section.id }} .gr-hero--full {
    min-height: calc(100vh - 104px);
  }

  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} {
      margin-top: 0 !important;
    }

    #shopify-section-{{ section.id }} .gr-hero {
      --gr-hero-focus: {{ section.settings.mobile_focus }};
      min-height: 0;
      display: block;
      padding-top: 64px;
    }

    #shopify-section-{{ section.id }} .gr-hero__media {
      position: relative;
    }

    #shopify-section-{{ section.id }} .gr-hero__media picture {
      height: auto;
    }

    #shopify-section-{{ section.id }} .gr-hero__media img,
    #shopify-section-{{ section.id }} .gr-hero__media video {
      width: 100%;
      height: auto;
      object-fit: initial;
    }

    #shopify-section-{{ section.id }} .gr-hero__content {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }
  }
</style>

{% if section.settings.overlay_style == 'custom' %}
  {% assign overlay_alpha = section.settings.overlay_opacity | divided_by: 100.0 %}
  <style>
    #shopify-section-{{ section.id }} {
      --gr-hero-overlay-start: {{ section.settings.overlay_color | color_modify: 'alpha', 0.3 }};
      --gr-hero-overlay-end: {{ section.settings.overlay_color | color_modify: 'alpha', overlay_alpha }};
    }
  </style>
{% endif %}

<div class="gr-hero gr-hero--{{ section.settings.height }} gr-reveal" {{ section.shopify_attributes }}>
  <div class="gr-hero__media">
    {% if section.settings.video != blank %}
      {{ section.settings.video | video_tag:
        autoplay: true,
        loop: true,
        muted: true,
        playsinline: true,
        loading: 'eager'
      }}
    {% elsif section.settings.image %}
      <picture>
        {% if section.settings.mobile_image %}
          <source media="(max-width: 768px)"
            srcset="{{ section.settings.mobile_image | image_url: width: 400 }} 400w,
                    {{ section.settings.mobile_image | image_url: width: 600 }} 600w,
                    {{ section.settings.mobile_image | image_url: width: 800 }} 800w"
            sizes="100vw" />
        {% endif %}
        {{ section.settings.image | image_url: width: 1920 | image_tag:
          loading: 'eager',
          sizes: '100vw',
          widths: '640, 960, 1280, 1600, 1920'
        }}
      </picture>
    {% endif %}
  </div>

  <div class="gr-hero__overlay gr-hero__overlay--{{ section.settings.overlay_style }}"></div>

  <div class="gr-hero__content">
    {% if section.settings.heading != blank %}
      <h1 class="gr-hero__title gr-heading">{{ section.settings.heading }}</h1>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="gr-hero__subtitle">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="gr-hero__actions">
      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="gr-btn gr-btn--primary">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
      {% if section.settings.button_label_2 != blank %}
        <a href="{{ section.settings.button_link_2 }}" class="gr-btn gr-btn--secondary">
          {{ section.settings.button_label_2 }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "GR Hero Banner",
  "tag": "section",
  "class": "gr-hero-wrapper",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image",
      "info": "Optional portrait image for mobile. If empty, the background image is used."
    },
    {
      "type": "video",
      "id": "video",
      "label": "Background Video (overrides image)"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Height",
      "options": [
        { "value": "full", "label": "Full Screen" },
        { "value": "default", "label": "Large (80vh)" },
        { "value": "medium", "label": "Medium (60vh)" }
      ],
      "default": "default"
    },
    {
      "type": "select",
      "id": "image_focus",
      "label": "Image focus point",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "center top", "label": "Top" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "left center", "label": "Left" },
        { "value": "right center", "label": "Right" }
      ],
      "default": "center center"
    },
    {
      "type": "header",
      "content": "Mobile display"
    },
    {
      "type": "range",
      "id": "mobile_height",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Mobile height",
      "default": 70
    },
    {
      "type": "select",
      "id": "mobile_fit",
      "label": "Mobile image fit",
      "info": "Cover fills the area (may crop). Contain shows the full image.",
      "options": [
        { "value": "cover", "label": "Cover (fill, may crop)" },
        { "value": "contain", "label": "Contain (full image, no crop)" }
      ],
      "default": "cover"
    },
    {
      "type": "select",
      "id": "mobile_focus",
      "label": "Mobile focus point",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "center top", "label": "Top" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "left center", "label": "Left" },
        { "value": "right center", "label": "Right" }
      ],
      "default": "center center"
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "select",
      "id": "overlay_style",
      "label": "Overlay",
      "options": [
        { "value": "dark", "label": "Dark Gradient" },
        { "value": "darker", "label": "Heavy Dark" },
        { "value": "blood", "label": "Blood Red Gradient" },
        { "value": "custom", "label": "Custom" }
      ],
      "default": "dark"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#0A0A0A"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 60
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "RIDE HARD. LIVE FAST."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Premium coffee for those who refuse to settle."
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Secondary Button"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Button Label"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "GR Hero Banner"
    }
  ]
}
{% endschema %}
