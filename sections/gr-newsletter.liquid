{%- comment -%}
  GR Newsletter — Matching gothrider.ca footer newsletter design.
  Floating-label email input with circular arrow submit button.
{%- endcomment -%}

<div class="gr-section gr-reveal" {{ section.shopify_attributes }}>
  <div class="gr-container">
    <div class="gr-newsletter gr-newsletter--{{ section.settings.style }}">
      <div class="gr-newsletter__content">
        {% if section.settings.heading != blank %}
          <h2 class="gr-newsletter__heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subtext != blank %}
          <p class="gr-newsletter__subtext">{{ section.settings.subtext }}</p>
        {% endif %}
      </div>

      <div class="gr-newsletter__form-wrapper">
        {% form 'customer', class: 'gr-newsletter__form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="gr-newsletter__input-group">
            <div class="gr-newsletter__field">
              <input
                type="email"
                name="contact[email]"
                id="gr-newsletter-email-{{ section.id }}"
                class="gr-newsletter__input"
                placeholder=" "
                required
                autocomplete="email"
                aria-label="{{ section.settings.placeholder | default: 'E-mail' }}"
              >
              <label class="gr-newsletter__label" for="gr-newsletter-email-{{ section.id }}">
                {{ section.settings.placeholder | default: 'E-mail' }}
              </label>
            </div>
            <button type="submit" class="gr-newsletter__submit" aria-label="{{ section.settings.button_label | default: 'Subscribe' }}">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M3.75 9H14.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M9.75 4.5L14.25 9L9.75 13.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
          {% if form.posted_successfully? %}
            <p class="gr-newsletter__success">{{ section.settings.success_message | default: "Welcome to the ride." }}</p>
          {% endif %}
          {% if form.errors %}
            <p class="gr-newsletter__error">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</p>
          {% endif %}
        {% endform %}
        {% if section.settings.disclaimer != blank %}
          <p class="gr-newsletter__disclaimer">{{ section.settings.disclaimer }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<style>
  .gr-newsletter {
    text-align: center;
    max-width: 600px;
    margin-inline: auto;
    padding: var(--gr-space-3xl) var(--gr-space-lg);
  }

  .gr-newsletter__content {
    margin-bottom: var(--gr-space-xl);
  }

  .gr-newsletter__heading {
    font-family: var(--gr-font-heading);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-style: italic;
    font-weight: 400;
    color: var(--gr-text-primary, #FFFFFF);
    line-height: 1.2;
    margin: 0;
  }

  .gr-newsletter--bordered {
    border: 1px solid var(--gr-border);
    border-radius: var(--gr-radius-md, 0.75rem);
  }

  .gr-newsletter--surface {
    background-color: var(--gr-surface);
    border-radius: var(--gr-radius-md, 0.75rem);
  }

  .gr-newsletter__subtext {
    color: var(--gr-text-secondary, #999999);
    margin-top: var(--gr-space-sm);
    margin-bottom: 0;
    line-height: var(--gr-leading-relaxed);
    font-size: var(--gr-body-md, 0.9375rem);
  }

  .gr-newsletter__form {
    width: 100%;
  }

  .gr-newsletter__input-group {
    position: relative;
    display: flex;
    align-items: center;
    max-width: 400px;
    margin-inline: auto;
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 8px;
    padding-right: 4px;
    transition: border-color 0.2s ease;
  }

  .gr-newsletter__input-group:focus-within {
    border-color: rgba(255, 255, 255, 0.4);
  }

  .gr-newsletter__field {
    flex: 1;
    position: relative;
    min-height: 48px;
  }

  .gr-newsletter__input {
    width: 100%;
    height: 48px;
    padding: 14px 16px 2px;
    background: transparent;
    border: none;
    color: var(--gr-text-primary, #FFFFFF);
    font-family: var(--gr-font-body);
    font-size: 0.875rem;
    outline: none;
    -webkit-appearance: none;
    appearance: none;
  }

  .gr-newsletter__input:-webkit-autofill,
  .gr-newsletter__input:-webkit-autofill:hover,
  .gr-newsletter__input:-webkit-autofill:focus {
    -webkit-text-fill-color: var(--gr-text-primary, #FFFFFF);
    -webkit-box-shadow: 0 0 0px 1000px rgba(255, 255, 255, 0.05) inset;
    transition: background-color 5000s ease-in-out 0s;
  }

  .gr-newsletter__label {
    position: absolute;
    top: 50%;
    left: 16px;
    transform: translateY(-50%);
    color: rgba(255, 255, 255, 0.5);
    font-family: var(--gr-font-body);
    font-size: 0.875rem;
    pointer-events: none;
    transition: all 0.2s ease;
    transform-origin: left center;
  }

  .gr-newsletter__input:focus ~ .gr-newsletter__label,
  .gr-newsletter__input:not(:placeholder-shown) ~ .gr-newsletter__label {
    top: 8px;
    transform: translateY(0) scale(0.75);
    color: rgba(255, 255, 255, 0.6);
  }

  .gr-newsletter__submit {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(255, 255, 255, 0.1);
    border: none;
    border-radius: 9999px;
    color: var(--gr-text-primary, #FFFFFF);
    cursor: pointer;
    transition: background-color 0.2s ease;
    padding: 0;
  }

  .gr-newsletter__submit:hover {
    background-color: rgba(255, 255, 255, 0.2);
  }

  .gr-newsletter__submit svg {
    display: block;
  }

  .gr-newsletter__success {
    color: var(--gr-success, #22c55e);
    margin-top: var(--gr-space-md);
    font-family: var(--gr-font-heading);
    text-transform: uppercase;
    letter-spacing: var(--gr-tracking-wide);
    font-size: var(--gr-body-sm, 0.8125rem);
  }

  .gr-newsletter__error {
    color: var(--gr-error, #ef4444);
    margin-top: var(--gr-space-md);
    font-size: var(--gr-body-sm, 0.8125rem);
  }

  .gr-newsletter__disclaimer {
    color: var(--gr-text-muted, #666666);
    font-size: var(--gr-body-xs, 0.75rem);
    margin-top: var(--gr-space-md);
  }

  @media (max-width: 768px) {
    .gr-newsletter {
      padding: var(--gr-space-2xl) var(--gr-space-lg);
    }

    .gr-newsletter__input-group {
      max-width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "GR Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Signup for Our Newsletter"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input label",
      "default": "E-mail"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Welcome to the ride."
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Disclaimer text"
    },
    {
      "type": "select",
      "id": "style",
      "label": "Style",
      "options": [
        { "value": "default", "label": "Default" },
        { "value": "bordered", "label": "Bordered" },
        { "value": "surface", "label": "Surface background" }
      ],
      "default": "default"
    }
  ],
  "presets": [
    {
      "name": "GR Newsletter"
    }
  ]
}
{% endschema %}
